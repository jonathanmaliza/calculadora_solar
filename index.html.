<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8">
<title>Calculadora Fotovoltaica</title>

<style>

body{
font-family: Arial, Helvetica, sans-serif;
margin:0;
padding:0;

/* Fondo solar */
background-image:url("https://images.unsplash.com/photo-1509395176047-4a66953fd231");
background-size:cover;
background-position:center;
background-attachment:fixed;
}

.container{

max-width:650px;
margin:60px auto;
background:rgba(255,255,255,0.92);
padding:30px;
border-radius:12px;
box-shadow:0px 0px 20px rgba(0,0,0,0.4);

}

h1{
text-align:center;
color:#e67e22;
}

label{
font-weight:bold;
}

input, select{

width:100%;
padding:10px;
margin-top:5px;
margin-bottom:15px;
border-radius:6px;
border:1px solid #ccc;

}

button{

width:100%;
padding:14px;
background:#f39c12;
border:none;
color:white;
font-size:18px;
border-radius:6px;
cursor:pointer;

}

button:hover{

background:#d35400;

}

.result{

margin-top:20px;
background:#ecf0f1;
padding:15px;
border-radius:8px;
line-height:1.6;

}

</style>

</head>

<body>

<script>

var password = "solar123"; 
var user = "";

while(user !== password){
    
    user = prompt("Ingrese la contraseña para usar la calculadora:");

    if(user !== password){
        alert("Contraseña incorrecta. Intente nuevamente.");
    }

}

</script>


<div class="container">

<h1>🌞 Calculadora Fotovoltaica</h1>

<label>Consumo mensual (kWh)</label>
<input type="number" id="consumo_mensual">

<label>Horas Solar Pico (HSP)</label>
<input type="number" id="hsp">

<label>Potencia del panel (W)</label>
<input type="number" id="potencia_panel">

<label>VOC del panel (V)</label>
<input type="number" id="voc_panel">

<label>Voltaje máximo MPPT inversor (V)</label>
<input type="number" id="mppt_max">

<label>Tipo inversor</label>
<select id="tipo_inversor">
<option value="1">OnGrid</option>
<option value="2">OffGrid</option>
<option value="3">Híbrido</option>
</select>

<label>Costo total inversión ($)</label>
<input type="number" id="costo_inversion">

<label>Tarifa eléctrica ($/kWh)</label>
<input type="number" id="tarifa">

<label>Factor de pérdidas (%)</label>
<input type="number" id="factor_perdidas">

<button onclick="calcular()">Calcular Sistema</button>

<div class="result" id="resultado"></div>

</div>

<script>

function calcular(){

let consumo_mensual = parseFloat(document.getElementById("consumo_mensual").value);

let hsp = parseFloat(document.getElementById("hsp").value);

let potencia_panel = parseFloat(document.getElementById("potencia_panel").value);

let voc_panel = parseFloat(document.getElementById("voc_panel").value);

let mppt_max = parseFloat(document.getElementById("mppt_max").value);

let costo_inversion = parseFloat(document.getElementById("costo_inversion").value);

let tarifa = parseFloat(document.getElementById("tarifa").value);

let factor_perdidas = parseFloat(document.getElementById("factor_perdidas").value);


/* cálculos */

let consumo_diario = consumo_mensual / 30;

let energia_requerida = consumo_diario / (1 - factor_perdidas / 100);

let potencia_sistema_kw = energia_requerida / hsp;

let potencia_panel_kw = potencia_panel / 1000;

let cantidad_paneles = Math.ceil(potencia_sistema_kw / potencia_panel_kw);

let max_paneles_serie = Math.floor(mppt_max / voc_panel);

let numero_strings = 0;

if(max_paneles_serie > 0){

numero_strings = Math.ceil(cantidad_paneles / max_paneles_serie);

}

let produccion_anual = energia_requerida * 365;

let ahorro_anual = produccion_anual * tarifa;

let retorno_inversion = 0;

if(ahorro_anual > 0){

retorno_inversion = costo_inversion / ahorro_anual;

}


/* mostrar resultados */

document.getElementById("resultado").innerHTML =

"<b>Consumo diario:</b> " + consumo_diario.toFixed(2) + " kWh<br>" +

"<b>Energía requerida con pérdidas:</b> " + energia_requerida.toFixed(2) + " kWh/día<br>" +

"<b>Potencia requerida sistema:</b> " + potencia_sistema_kw.toFixed(2) + " kW<br>" +

"<b>Cantidad de paneles necesarios:</b> " + cantidad_paneles + "<br>" +

"<b>Máx. paneles en serie por VOC:</b> " + max_paneles_serie + "<br>" +

"<b>Número de strings requeridas:</b> " + numero_strings + "<br>" +

"<b>Producción anual estimada:</b> " + produccion_anual.toFixed(2) + " kWh<br>" +

"<b>Ahorro anual estimado:</b> $" + ahorro_anual.toFixed(2) + "<br>" +

"<b>Retorno de inversión:</b> " + retorno_inversion.toFixed(2) + " años";

}

</script>

</body>
</html>
